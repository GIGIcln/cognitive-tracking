# Database
DATABASE_URL=postgresql://user:password@localhost:5432/cognitive_tracking

# Security
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# App
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:5173

# Notifiche push (ntfy.sh) — opzionale, invia il link del tunnel al telefono
# Setup: installa l'app "ntfy" (Android/iOS), scegli un nome topic unico
# e iscriviti a quel topic nell'app. Nessun account richiesto.
NTFY_TOPIC=

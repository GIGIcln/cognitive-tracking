# Copia questo file in .env.production e compila i valori reali.
# .env.production NON deve essere committato (già in .gitignore).

# Chiave segreta JWT — genera con:
#   openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# Password PostgreSQL — scegli una password robusta
POSTGRES_PASSWORD=change-me-strong-password

# Origine consentita per CORS — il tuo dominio Cloudflare (senza slash finale)
# Esempio: https://gestionale.example.com
ALLOWED_ORIGINS=https://il-tuo-dominio.example.com
